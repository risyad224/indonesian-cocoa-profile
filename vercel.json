{
  "version": 2,
  "framework": null,
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0",
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "env": {
    "VERCEL": "1",
    "APP_KEY": "@APP_KEY",
    "APP_NAME": "Indonesian Cocoa Profile",
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "APP_URL": "@APP_URL"
  }
}