{
  "version": 2,
  "framework": null,
  "outputDirectory": "public",
  "buildCommand": "npm install --include=dev && npm run build",
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0",
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/",
      "dest": "/api/index.php"
    },
    {
      "src": "/index\\.php",
      "dest": "/api/index.php"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "env": {
    "APP_KEY": "base64:sSjbtRK/7m2J+O25p3GW/khZhlXhUFWBkAbbJLCDfDI=",
    "APP_NAME": "Indonesian Cocoa Profile",
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "LOG_CHANNEL": "stderr",
    "VERCEL": "1",
    "APP_SERVICES_CACHE": "/tmp/storage/bootstrap/cache/services.php",
    "APP_PACKAGES_CACHE": "/tmp/storage/bootstrap/cache/packages.php",
    "APP_CONFIG_CACHE": "/tmp/storage/bootstrap/cache/config.php",
    "APP_ROUTES_CACHE": "/tmp/storage/bootstrap/cache/routes.php",
    "APP_EVENTS_CACHE": "/tmp/storage/bootstrap/cache/events.php",
    "VIEW_COMPILED_PATH": "/tmp/storage/framework/views"
  },
  "build": {
    "env": {
      "SKIP_ENV_VALIDATION": "true",
      "NODE_ENV": "production"
    }
  }
}